# ============================================================
# GEOFlow 单容器部署 .env 示例
# 数据库和 Redis 使用 1Panel 已有的远程服务
# ============================================================
APP_NAME=GEOFlow
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
TRUSTED_PROXIES=*
BOOST_BROWSER_LOGS_WATCHER=false
APP_TIMEZONE=Asia/Shanghai

# --- GEOFlow 配置 ---
SITE_NAME="智能GEO内容系统"
SITE_FULL_NAME="GEO+AI内容生成系统"
SITE_URL="${APP_URL}"
SITE_DESCRIPTION=
SITE_KEYWORDS=
ADMIN_BASE_PATH=geo_admin
GEOFLOW_PUBLIC_LOCALE=zh_CN
GEOFLOW_ITEMS_PER_PAGE=12
GEOFLOW_ADMIN_ITEMS_PER_PAGE=20
GEOFLOW_TITLE_AI_KEYWORD_SAMPLE_LIMIT=10
GEOFLOW_DEBUG_KNOWLEDGE_QUERY_EMBEDDING=false
URL_IMPORT_ALLOW_MIXED_DNS=false
GEOFLOW_UPLOAD_URL=/assets/images/
GEOFLOW_MAX_UPLOAD_BYTES=2097152
GEOFLOW_CACHE_ENABLED=true
GEOFLOW_CACHE_TTL=3600
GEOFLOW_MAX_LOGIN_ATTEMPTS=5
GEOFLOW_LOGIN_LOCKOUT_SECONDS=900
GEOFLOW_SESSION_TIMEOUT=2592000
GEOFLOW_API_LOGIN_RATE_LIMIT_ATTEMPTS=10
GEOFLOW_API_LOGIN_RATE_LIMIT_DECAY=60
GEOFLOW_API_TOKEN_DEFAULT_TTL_DAYS=30
GEOFLOW_ADMIN_USERNAME=admin
GEOFLOW_ADMIN_EMAIL=admin@example.com
GEOFLOW_ADMIN_PASSWORD=
GEOFLOW_APP_VERSION=2.0
GEOFLOW_WELCOME_INTRO_VERSION=2.0
GEOFLOW_UPDATE_CHECK_ENABLED=true
GEOFLOW_UPDATE_METADATA_URL=https://raw.githubusercontent.com/yaojingang/GEOFlow/main/version.json
GEOFLOW_UPDATE_METADATA_CACHE_TTL=86400

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ============================================================
# ⚠️ 远程数据库（1Panel 管理）
# 替换为你的 1Panel PostgreSQL 连接信息
# ============================================================
DB_CONNECTION=pgsql
DB_HOST=192.168.1.100        # ← 改为 1Panel 上 PostgreSQL 的内网 IP
DB_PORT=5432
DB_DATABASE=geo_flow
DB_USERNAME=geo_user
DB_PASSWORD=your_strong_password_here

SESSION_DRIVER=file
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Laravel Reverb（WebSocket，通过 Nginx 同端口 18080 代理） ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=geoflow-reverb-app
REVERB_APP_KEY=geoflow-reverb-key
REVERB_APP_SECRET=change-this-reverb-secret
# 前端连接地址（走 Nginx 代理，与 HTTP 同端口 18080）
REVERB_HOST=localhost
REVERB_PORT=18080
REVERB_SCHEME=http
# Reverb 服务端内部监听端口（容器内不暴露到外部）
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=18081

FILESYSTEM_DISK=local

# ============================================================
# ⚠️ 远程 Redis（1Panel 管理）
# 队列 + 缓存均使用远程 Redis
# ============================================================
QUEUE_CONNECTION=redis
CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=192.168.1.100      # ← 改为 1Panel 上 Redis 的内网 IP
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379
REDIS_QUEUE_RETRY_AFTER=360

# --- 邮件 ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- 单容器 entrypoint 配置 ---
# 每次启动自动 migration（默认开）
AUTO_MIGRATE=true
# 首次部署 seed（首次开一次，之后设为 false）
AUTO_SEED=false
# 启动后执行 php artisan optimize
AUTO_OPTIMIZE=true
# 启动时等待 PostgreSQL（需要时开）
AUTO_WAIT_FOR_DB=true
