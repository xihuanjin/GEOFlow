{
  "id": "apple_support_clone",
  "name": "Apple Support Inspired",
  "version": "1.0.0",
  "mode": "clone",
  "framework": "laravel",
  "geoflow_contract": "site-theme-view-resolver",
  "created_at": "2026-05-30",
  "description": "Apple.com and Apple Support inspired GEOFlow frontend theme. It keeps GEOFlow routes and article/category data contracts intact.",
  "source_reference_url": [
    "https://www.apple.com/",
    "https://support.apple.com/en-us/102655",
    "https://support.apple.com/mac"
  ],
  "compatible_pages": [
    "home",
    "article",
    "category",
    "archive-index",
    "archive-month"
  ],
  "compatible_modules": [
    "layout",
    "home.hero",
    "home.featured_articles",
    "home.latest_articles",
    "category.header",
    "category.article_list",
    "article.header",
    "article.prose",
    "article.tags",
    "article.related_articles",
    "article.sticky_ad",
    "archive.overview",
    "archive.article_list"
  ],
  "preview_routes": [
    "/",
    "/category/{slug}",
    "/article/{slug}",
    "/archive"
  ],
  "requires_admin_activation": true,
  "blade_templates": [
    "layout.blade.php",
    "home.blade.php",
    "article.blade.php",
    "category.blade.php",
    "archive-index.blade.php",
    "archive-month.blade.php",
    "partials/article-card.blade.php"
  ],
  "fallback_templates": [],
  "notes": "Preview requires selecting this theme in admin site settings or using static rendered review, because this Laravel app has no isolated theme preview route."
}
